#!/usr/bin/env bash
#
# kcomm - Python 主入口包装脚本
# 保留仓库级 `./kcomm` 作为主命令，实际执行 Python 版 CLI。
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="${PYTHON:-python3}"

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  echo "kcomm: 未找到 $PYTHON_BIN，请先安装 Python 3 或设置 PYTHON 环境变量。" >&2
  exit 1
fi

exec "$PYTHON_BIN" "$SCRIPT_DIR/kcomm.py" "$@"
